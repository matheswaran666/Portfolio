    <meta name="description" content="Sign in to your Zoho account and access all your apps. If you don&#39;t have an account, you can sign up for one."/>
		<style type="text/css" nonce="W63q5zicqXM+j88YYQob3Q==">
			.signin_box {
				width: 500px;
				height: auto;
				background: #fff;
				box-sizing: border-box;
				padding: 50px 50px;
				border-radius: 6px;
				transition: all .1s ease-in-out;
				float: left;
				overflow-y: auto;
				display: table-cell;
				border-right: 2px solid #f1f1f1;
			}
			@media (min-width: 600px) and (max-width: 1024px) {
				.signin_box {   
					width: 100%;
					border-right: none;
			    }
			}
			@media only screen and (max-width: 600px) {
				.signin_box {   
					width: 100%;
				    padding: 0px 30px;
				    height: auto;
				    border-right: none;
			    }
			}
			body{margin: 0px;}
			.load-bg{top:0px}
			.darkmode .load-bg{background-color: #191A23}
			.line_loader{transform: scale(1);}
			
